{
  "default_route_id_enabled": true,
  "route_id_cleanup_regex": "\\d$",
  "route_id_cleanup_regex_comment": "remove end with digit",
  "route_id_not_unique_allowed": true,
  "use_route_short_name_for_route_id": true,
  "route_short_name_to_route_id_configs": [
    {
      "route_short_name": "REM",
      "route_id": 4001
    }
  ],
  "route_short_name_cleaners": [
    {
      "regex": ".+",
      "replacement": "REM"
    }
  ],
  "default_route_long_name_enabled": true,
  "direction_finder_enabled": true,
  "direction_headsign_cleaners": [
    {
      "regex": "^A[\\d]+\\s*\\-\\s*"
    }
  ],
  "trip_id_cleanup_regex": "^((MAV-)?RDS-)|((-\\(GTFS\\))?(\\.xml(\\s\\(GTFS\\))?(\\.xml)?))",
  "trip_headsign_cleaners": [
    {
      "regex": "(^(A\\d+)\\s+-\\s+)",
      "ignore_case": true,
      "replacement": "$2:"
    }
  ],
  "use_parent_stop_id_for_stop_id": true,
  "stop_id_cleanup_regex": "_\\d+$",
